# ScholarAI Environment Configuration
# Copy this to .env and fill in your values

# GitHub Token for elevated API access (get one at https://github.com/settings/tokens)
GITHUB_TOKEN=

# Google Sheets integration (optional - for syncing data to Google Sheets)
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_SPREADSHEET_ID=

# Application environment: development or production
SCHOLARAI_ENV=development

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
